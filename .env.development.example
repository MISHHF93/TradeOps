# TradeOps — development (extends .env.example)
# Copy: copy .env.example .env  then merge any overrides below.

NODE_ENV=development
LOG_LEVEL=debug
TRADEOPS_ACCESS_MODE=founder_direct
NEXT_PUBLIC_TRADEOPS_ACCESS_MODE=founder_direct
AUTH_BYPASS=true
TRADEOPS_SIMULATION_MODE=0

API_HOST=127.0.0.1
WEB_HOST=127.0.0.1
API_PUBLIC_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_PUBLIC_URL=http://127.0.0.1:4000
WEB_ORIGIN=http://localhost:3000

# Local PGlite default
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:51214/template1?schema=public&sslmode=disable&pgbouncer=true&connection_limit=5

# Active stack credentials (optional for UI; required for live probes)
COHERE_API_KEY=
TAVILY_API_KEY=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
EASYPOST_API_KEY=
