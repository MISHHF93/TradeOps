# TradeOps — development (extends .env.example)
# Copy: copy .env.example .env  then merge any overrides below.
# Development minimum — values go into gitignored .env only.

NODE_ENV=development
LOG_LEVEL=debug
TRADEOPS_ACCESS_MODE=founder_direct
NEXT_PUBLIC_TRADEOPS_ACCESS_MODE=founder_direct
AUTH_BYPASS=true
TRADEOPS_SIMULATION_MODE=0
ENABLE_SIMULATION_MODE=false

API_HOST=127.0.0.1
API_PORT=4000
WEB_HOST=127.0.0.1
WEB_PORT=3000
API_PUBLIC_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_PUBLIC_URL=http://127.0.0.1:4000
WEB_ORIGIN=http://localhost:3000

# Local PGlite default
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:51214/template1?schema=public&sslmode=disable&pgbouncer=true&connection_limit=5
REDIS_URL=redis://localhost:6379
APP_SECRET=dev-only-change-me-to-a-long-random-string
CREDENTIALS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# AI runtime (Cohere code-first; optional for UI; required for live probes)
AI_PROVIDER=cohere
AI_RUNTIME_ENABLED=true
AI_RESPONSE_CACHE_ENABLED=false
COHERE_API_KEY=
COHERE_CHAT_MODEL=command-a-03-2025
WEB_SEARCH_ENABLED=false
TAVILY_API_KEY=

# Optional live commerce connectors (empty = honest block / fixture paths)
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
EASYPOST_API_KEY=
