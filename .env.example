# Platform
NODE_ENV=development
LOG_LEVEL=info

# ——— SECURITY (read docs/TRADEOPS_INTERNET_SECURITY.md) ———
# Loopback-only binds: required for founder_direct on a machine connected to LAN/Wi‑Fi.
# Never use API_HOST=0.0.0.0 with founder_direct on the public internet.
API_PORT=4000
API_HOST=127.0.0.1
WEB_PORT=3000
WEB_HOST=127.0.0.1
WEB_ORIGIN=http://localhost:3000
# Use 127.0.0.1 (not localhost) to avoid Windows IPv6 SSR hang issues
API_PUBLIC_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_PUBLIC_URL=http://127.0.0.1:4000
# Opt-in only — allows founder_direct on 0.0.0.0 (dangerous)
# TRADEOPS_ALLOW_INSECURE_BIND=0
# TRADEOPS_ALLOW_PUBLIC_FOUNDER=0
# TRADEOPS_SECURITY_BOOT=strict

# PostgreSQL — pick one:
# A) System/Docker Postgres:
# DATABASE_URL=postgresql://tradeops:tradeops@127.0.0.1:5432/tradeops?schema=public&connect_timeout=2
# B) Prisma Dev / PGlite (default for App Control Windows hosts — pnpm run db:pglite).
#    pgbouncer=true is required so Prisma does not use prepared statements (PGlite quirk).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:51214/template1?schema=public&sslmode=disable&pgbouncer=true&connection_limit=5

# Redis
REDIS_URL=redis://localhost:6379

# Secrets — generate with: node scripts/generate-secrets.mjs --write
# Do not use the placeholders below outside a disposable local sandbox.
APP_SECRET=dev-only-change-me-to-a-long-random-string
# 32-byte key as base64 for envelope encryption of connector credentials
CREDENTIALS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# Session cookie + DB lifetime (hours). Default 7 days.
SESSION_TTL_HOURS=168

# Local-only: skip login and use the seeded demo owner (founder@tradeops.local).
# Forced off when NODE_ENV=production. Set false to test real session auth.
AUTH_BYPASS=true

# Web → API fetch timeout (ms). Default 60000 — PGlite often needs more than 4s.
API_TIMEOUT_MS=60000
NEXT_PUBLIC_API_TIMEOUT_MS=60000

# Google Merchant weekend automation (optional live credentials)
# Without these, weekend jobs run in shadow mode only — never claim live success.
# GOOGLE_MERCHANT_ACCESS_TOKEN=
# GOOGLE_MERCHANT_ID=
# GOOGLE_MERCHANT_DATA_SOURCE_ID=

# Access mode (central switch — do not scatter conditionals elsewhere)
# founder_direct  = no login; auto founder workspace (default for this phase)
# authenticated   = session cookie required
# multi_tenant    = SaaS multi-user (same auth path as authenticated)
TRADEOPS_ACCESS_MODE=founder_direct
NEXT_PUBLIC_TRADEOPS_ACCESS_MODE=founder_direct
# Force public-deployment warning even on localhost (optional)
# TRADEOPS_PUBLIC_WARNING=false

# ——— SaaS billing (Stripe) — orgs pay TradeOps ———
# Without STRIPE_SECRET_KEY, checkout uses development fixture (no card data).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Optional Price IDs (Dashboard → Products → Prices):
# STRIPE_PRICE_FOUNDER_MONTHLY=price_...
# STRIPE_PRICE_FOUNDER_ANNUAL=price_...
# STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...
# STRIPE_PRICE_AGENCY_MONTHLY=price_...
# STRIPE_PRICE_AGENCY_ANNUAL=price_...
# STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
# STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...
# Allow sourcing when payment is authorized but not yet captured (default: false)
# TRADEOPS_ALLOW_AUTHORIZED_SOURCING=false

# ——— Financial feature gates (Commerce Capital / Connect) ———
# All investment-sensitive gates default OFF. Sandbox design defaults ON.
# CAPITAL_SANDBOX_ENABLED=true
# PRIVATE_AGREEMENT_LEDGER_ENABLED=false
# CAPITAL_NETWORK_ENABLED=false
# PUBLIC_CAMPAIGNS_ENABLED=false
# INVESTOR_ONBOARDING_ENABLED=false
# PROFIT_SHARING_ENABLED=false
# EQUITY_OFFERINGS_ENABLED=false
# POOLED_INVESTMENT_ENABLED=false
# AUTOMATED_INVESTMENT_ADVICE_ENABLED=false
# CAPITAL_CUSTODY_ENABLED=false
# DISTRIBUTIONS_ENABLED=false
# MARKETPLACE_CONNECT_ENABLED=false

# ——— Client-owned commerce network (recommended launch mode) ———
# TRADEOPS_CAPITAL_MODE=client_owned
# Hard blocks (forced OFF in production even if set true):
# TRADEOPS_POOLED_INVESTMENT_ENABLED=false
# TRADEOPS_GUARANTEED_RETURNS_ENABLED=false
# TRADEOPS_INTERNAL_CUSTODY_ENABLED=false


# When 1, UI shows simulation banner (fixture/model data may be present)
TRADEOPS_SIMULATION_MODE=0
# When 1 (or NODE_ENV=production without simulation), exclude fixture rows from scanner/portfolio KPIs
# TRADEOPS_PRODUCTION_WORKSPACE=0

# ——— Primary AI: xAI (SpaceXAI / Grok) + RAG ———
# Get a key: https://console.x.ai  (server-side only — never NEXT_PUBLIC_*)
# Without a key: tools + local RAG still work (tools_only mode).
# With a key: default mode auto → xai_rag (RAG retrieve → Grok answer).
#
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_CHAT_MODEL=grok-4.5
# XAI_EMBED_MODEL=                    # optional; empty = local dense only
# TRADEOPS_AI_MODE=auto               # auto | tools_only | xai_rag | xai_rag_tools | xai_disabled
# TRADEOPS_AI_DEFAULT_GENERATE=1      # when xAI mode active, RAG query generates by default
# TRADEOPS_AI_TIMEOUT_MS=60000
# TRADEOPS_STORAGE_DIR=               # RAG index files (default .tradeops-storage)


# Ops scheduler (optional)
# TRADEOPS_OPS_SYNC_DISABLED=0
# TRADEOPS_LIVE_SYNC_DISABLED=0
# TRADEOPS_WEBHOOK_DRAIN_MS=15000
# TRADEOPS_CONNECTOR_PROBE_MS=300000
# TRADEOPS_LIVE_SYNC_MS=900000
# Per-provider minimum gap between automatic live HTTP syncs (ms)
# TRADEOPS_LIVE_SYNC_PROVIDER_COOLDOWN_MS=300000

# =============================================================================
# VENDOR API KEYS CATALOG (auto-synced from production connector registry)
# Fill values after =  |  Leave empty to stay in fixture/shadow mode
# Never commit real secrets  |  Never use NEXT_PUBLIC_* for private keys
# Docs: docs/TRADEOPS_API_KEYS_CATALOG.md  |  Re-run: pnpm run env:sync-keys
# =============================================================================

