# =============================================================================
# TradeOps environment TEMPLATE — derived from CURRENT SOURCE CODE (safe to commit; no real secrets)
# Loaded by: packages/config loadDotEnvFiles() → loadEnv() / envSchema
#
# Active plan (ai-runtime provider-abstraction + web-search-provider):
#   COHERE_*  = sole generative provider (Phase B briefing / chat / embed / rerank)
#   TAVILY_*  = sole public web research provider
#   XAI_*     = NOT used for generation (code may read for diagnostics only)
# =============================================================================

# --- Platform (packages/config envSchema) ---
NODE_ENV=development
LOG_LEVEL=info

API_PORT=4000
API_HOST=127.0.0.1
WEB_PORT=3000
WEB_HOST=127.0.0.1
WEB_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_PUBLIC_URL=http://127.0.0.1:4000

# Database / PGlite (scripts/prisma-dev-db.mjs, packages/database)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:51214/template1?schema=public&sslmode=disable&pgbouncer=true&connection_limit=5
PRISMA_DEV_DB_PORT=51214

REDIS_URL=redis://localhost:6379

# Secrets (envSchema)
APP_SECRET=dev-only-change-me-to-a-long-random-string
CREDENTIALS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
SESSION_TTL_HOURS=168

AUTH_BYPASS=true
API_TIMEOUT_MS=60000
NEXT_PUBLIC_API_TIMEOUT_MS=60000

# Access mode (packages/config access-mode.ts)
TRADEOPS_ACCESS_MODE=founder_direct
NEXT_PUBLIC_TRADEOPS_ACCESS_MODE=founder_direct
TRADEOPS_PUBLIC_WARNING=false
TRADEOPS_SIMULATION_MODE=0
NEXT_PUBLIC_TRADEOPS_SIMULATION_MODE=0
TRADEOPS_ALLOW_INSECURE_BIND=0
TRADEOPS_ALLOW_PUBLIC_FOUNDER=0

# =============================================================================
# AI — Cohere only (Phase B generative briefing / Chat V2 / Embed / Rerank)
# Loaded by packages/config loadDotEnvFiles → loadEnv (server/API only).
# Without COHERE_API_KEY: tools still rank products; Phase B blocks honestly
# (no fixed product essay, no fixture narrative substitution).
# Never put this key in apps/web or NEXT_PUBLIC_*.
# Deep probe: GET /api/v1/ai/health?deep=true
# =============================================================================
COHERE_API_KEY=
COHERE_CHAT_MODEL=command-a-plus-05-2026
COHERE_EMBED_MODEL=embed-v4.0
COHERE_RERANK_MODEL=rerank-v3.5
AI_PROVIDER=cohere

# --- Public web research: Tavily only (packages/ai-runtime web-search-provider) ---
TAVILY_API_KEY=

# Operator loopMode (apps/api ai-operator.service — sidebar does NOT force shadow)
TRADEOPS_CONTROLLED_LIVE=0
TRADEOPS_FORCE_FIXTURE=0

# --- Optional live commerce connectors (empty = honest block / fixture paths) ---
# Shopify (live-http connector + lifecycle-path + diagnostics)
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# Stripe SaaS billing (billing.service) + optional publishable for browser
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# EasyPost logistics (diagnostics)
EASYPOST_API_KEY=

# Google Merchant weekend shadow (google-weekend.service / worker) — optional
# GOOGLE_MERCHANT_ACCESS_TOKEN=
# GOOGLE_MERCHANT_ID=
# GOOGLE_MERCHANT_DATA_SOURCE_ID=

# Analytics / observability (optional)
GA4_PROPERTY_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GA4_ENABLED=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Public site SEO (apps/web seo/robots/sitemap) — optional
# NEXT_PUBLIC_SITE_URL=

# --- Capital / financial gates (packages/config financial-gates + capital-mode) ---
# Defaults: sandbox ON; investment-sensitive OFF. Production hard-blocks pooled/custody.
TRADEOPS_CAPITAL_MODE=client_owned
CAPITAL_SANDBOX_ENABLED=true
PRIVATE_AGREEMENT_LEDGER_ENABLED=false
CAPITAL_NETWORK_ENABLED=false
PUBLIC_CAMPAIGNS_ENABLED=false
INVESTOR_ONBOARDING_ENABLED=false
PROFIT_SHARING_ENABLED=false
EQUITY_OFFERINGS_ENABLED=false
POOLED_INVESTMENT_ENABLED=false
AUTOMATED_INVESTMENT_ADVICE_ENABLED=false
CAPITAL_CUSTODY_ENABLED=false
DISTRIBUTIONS_ENABLED=false
MARKETPLACE_CONNECT_ENABLED=false
TRADEOPS_POOLED_INVESTMENT_ENABLED=false
TRADEOPS_GUARANTEED_RETURNS_ENABLED=false
TRADEOPS_INTERNAL_CUSTODY_ENABLED=false

# Billing commerce payment readiness (commerce-payment.service)
TRADEOPS_ALLOW_AUTHORIZED_SOURCING=false

# Optional ops tunables (apps/api commerce/ops-sync.scheduler) — defaults in code
# TRADEOPS_LIVE_SYNC_MS=
# TRADEOPS_LIVE_SYNC_DISABLED=
# TRADEOPS_OPS_SYNC_DISABLED=
# TRADEOPS_WEBHOOK_DRAIN_MS=
# TRADEOPS_CONNECTOR_PROBE_MS=
# ARTIFACT_STORAGE_ROOT=
