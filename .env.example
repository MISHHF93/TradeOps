# Live product projection (SSE)
LIVE_PROJECTION_ENABLED=true
LIVE_PROJECTION_TRANSPORT=sse
LIVE_PROJECTION_MAX_SOURCES=6
LIVE_PROJECTION_MAX_ITEMS=50
LIVE_PROJECTION_TIMEOUT_MS=120000
