# =============================================================================
# TradeOps — CANONICAL environment template (NO REAL SECRETS)
# =============================================================================
# Copy to gitignored `.env` and fill values. Never commit filled files.
# Architecture (from codebase):
#   - AI: Cohere code-first runtime (AI_PROVIDER=cohere) — not Playground-first
#   - Search: TradeOps Search Manager (WEB_SEARCH_* / Tavily / OpenAI optional)
#   - Secrets: platform keys in .env / secret manager; merchant keys in connector vault
#   - Access: TRADEOPS_ACCESS_MODE=founder_direct | authenticated | multi_tenant
#
# Compromised keys (pasted in chat/logs): rotate immediately; leave blank here.
# Scan:   node scripts/scan-env-keys.mjs
# Manifest: packages/config/src/environment-manifest.ts
# Vendor paste sheet: env.vendors.template
# =============================================================================

# --- Core ---
NODE_ENV=development
LOG_LEVEL=info
API_HOST=127.0.0.1
API_PORT=4000
WEB_HOST=127.0.0.1
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_PUBLIC_URL=http://127.0.0.1:4000
API_TIMEOUT_MS=60000
NEXT_PUBLIC_API_TIMEOUT_MS=60000
# NEXT_PUBLIC_SITE_URL=

# --- Database / Redis ---
# Local Prisma Dev (PGlite): pnpm db:pglite
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:51214/template1?schema=public&sslmode=disable&pgbouncer=true&connection_limit=5
REDIS_URL=redis://localhost:6379
PRISMA_DEV_DB_PORT=51214
PRISMA_DEV_NAME=tradeops

# --- Security (generate strong values for any shared/deployed env) ---
APP_SECRET=dev-only-change-me-to-a-long-random-string
CREDENTIALS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
SESSION_TTL_HOURS=168
TRADEOPS_SECURITY_BOOT=
TRADEOPS_ENV_VALIDATION=
# TRADEOPS_ALLOW_INSECURE_BIND=
# TRADEOPS_ALLOW_PUBLIC_FOUNDER=

# --- Access / tenancy ---
# production multi-user: authenticated | multi_tenant
TRADEOPS_ACCESS_MODE=founder_direct
AUTH_BYPASS=true
NEXT_PUBLIC_TRADEOPS_ACCESS_MODE=
TRADEOPS_PUBLIC_WARNING=
# TRADEOPS_PRODUCTION_WORKSPACE=

# =============================================================================
# AI RUNTIME — Cohere (code-first; server-only)
# =============================================================================
AI_PROVIDER=cohere
AI_RUNTIME_ENABLED=true
ENABLE_SIMULATION_MODE=false
TRADEOPS_SIMULATION_MODE=false
AI_RESPONSE_CACHE_ENABLED=false
# Set ONLY in gitignored .env or secret manager — never commit real keys
# If a key was ever pasted into chat, rotate it and put the NEW value here
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com
COHERE_CHAT_MODEL=command-a-03-2025
COHERE_EMBED_MODEL=embed-v4.0
COHERE_RERANK_MODEL=rerank-v3.5
COHERE_TEMPERATURE=0.2
COHERE_MAX_TOKENS=4000
COHERE_TIMEOUT_MS=60000
COHERE_MAX_RETRIES=2
COHERE_RETRIEVAL_ENABLED=true

AI_STRUCTURED_OUTPUT_ENABLED=true
AI_TOOL_CALLING_ENABLED=true
AI_STREAMING_ENABLED=true
AI_TEXT_OUTPUT_ENABLED=true
AI_RESPONSE_MODE=json_schema
AI_OUTPUT_SCHEMA_VERSION=1.0
AI_MAX_TOOL_ROUNDS=8
AI_MAX_TOOL_CALLS=15
AI_MAX_EXECUTION_SECONDS=120
AI_REQUIRE_APPROVAL_FOR_WRITES=true
AI_REQUIRE_APPROVAL_FOR_PAYMENTS=true
AI_REQUIRE_APPROVAL_FOR_REFUNDS=true
AI_REQUIRE_APPROVAL_FOR_PUBLISHING=true
# AI_INCLUDE_TEXT_OUTPUT=true
# AI_INCLUDE_JSON_OUTPUT=true
# AI_INCLUDE_EVIDENCE=true
# AI_INCLUDE_ACTIONS=true
# AI_INCLUDE_CONFIDENCE=true
# AI_PROMPT_VERSION=

# =============================================================================
# WEB SEARCH — TradeOps Search Manager (optional; not Cohere-as-internet)
# =============================================================================
WEB_SEARCH_ENABLED=false
SEARCH_PROVIDER_PRIMARY=openai
SEARCH_PROVIDER_RETRIEVAL=openai
SEARCH_PROVIDER_INTERNAL=cohere
SEARCH_REQUIRE_CITATIONS=true
SEARCH_REQUIRE_SOURCE_TIMESTAMPS=false
SEARCH_MAX_QUERIES_PER_REQUEST=6
SEARCH_MAX_RESULTS_PER_QUERY=10
SEARCH_DEFAULT_CACHE_TTL_SECONDS=3600
# SEARCH_ALLOWED_DOMAINS=
# SEARCH_BLOCKED_DOMAINS=
TAVILY_API_KEY=
TAVILY_SEARCH_ENABLED=true
TAVILY_EXTRACT_ENABLED=true
TAVILY_CRAWL_ENABLED=true
TAVILY_RESEARCH_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_WEB_SEARCH_ENABLED=true

# Optional alternate generation (not primary runtime)
XAI_API_KEY=
XAI_MODEL=
XAI_BASE_URL=https://api.x.ai/v1
# XAI_EMBED_MODEL=
# XAI_WEB_SEARCH_ENABLED=true
# XAI_X_SEARCH_ENABLED=true
# XAI_SEARCH_MAX_CALLS=5
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=

# =============================================================================
# Platform SaaS billing (optional)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_FOUNDER_MONTHLY=
# STRIPE_PRICE_FOUNDER_ANNUAL=
# STRIPE_PRICE_PROFESSIONAL_MONTHLY=
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=
# STRIPE_PRICE_AGENCY_MONTHLY=
# STRIPE_PRICE_AGENCY_ANNUAL=
# STRIPE_PRICE_ENTERPRISE_MONTHLY=
# STRIPE_PRICE_ENTERPRISE_ANNUAL=

