# Production example — inject secrets via platform secret manager only
AI_PROVIDER=cohere
COHERE_API_KEY=
COHERE_CHAT_MODEL=command-a-03-2025
COHERE_EMBED_MODEL=embed-v4.0
COHERE_RERANK_MODEL=rerank-v3.5
AI_REQUIRE_APPROVAL_FOR_WRITES=true
WEB_SEARCH_ENABLED=false
# WEB_SEARCH_ENABLED=true requires OPENAI_API_KEY and/or TAVILY_API_KEY
NODE_ENV=production
