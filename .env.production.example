# TradeOps — production template (approved stack only)
# Production — names only, values from secret manager. Never commit real secrets.

NODE_ENV=production
LOG_LEVEL=info

# Public bind — set hosts/origins to real domains
API_PORT=4000
API_HOST=0.0.0.0
WEB_ORIGIN=https://app.example.com
API_PUBLIC_URL=https://api.example.com
NEXT_PUBLIC_API_PUBLIC_URL=https://api.example.com

# Use multi_tenant or authenticated in real SaaS
TRADEOPS_ACCESS_MODE=multi_tenant
NEXT_PUBLIC_TRADEOPS_ACCESS_MODE=multi_tenant
AUTH_BYPASS=false
TRADEOPS_SIMULATION_MODE=0
ENABLE_SIMULATION_MODE=false
TRADEOPS_ALLOW_PUBLIC_FOUNDER=0
TRADEOPS_ALLOW_INSECURE_BIND=0

DATABASE_URL=postgresql://USER:PASS@HOST:5432/tradeops?schema=public
REDIS_URL=redis://HOST:6379

APP_SECRET=
CREDENTIALS_MASTER_KEY=
SESSION_TTL_HOURS=168

# AI — Cohere code-first runtime (server-side only)
AI_PROVIDER=cohere
AI_RUNTIME_ENABLED=true
AI_RESPONSE_CACHE_ENABLED=false
COHERE_API_KEY=
COHERE_CHAT_MODEL=command-a-03-2025
COHERE_EMBED_MODEL=embed-v4.0
COHERE_RERANK_MODEL=rerank-v3.5

# Public research — enable only with a configured provider
WEB_SEARCH_ENABLED=false
TAVILY_API_KEY=
# When enabling web search, also set TAVILY_API_KEY or OPENAI_API_KEY

# Commerce — prefer tenant vault for store tokens; platform keys only if single-tenant
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
# Merchant tokens: encrypted connector vault per organization (not global env)

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Logistics
EASYPOST_API_KEY=

# Analytics
GA4_PROPERTY_ID=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Observability
SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=tradeops-api
