# TradeOps — test environment
# Used by CI / local automated tests. No real vendor secrets.

NODE_ENV=test
LOG_LEVEL=error
TRADEOPS_ACCESS_MODE=founder_direct
AUTH_BYPASS=true

API_PORT=4001
WEB_PORT=3001
API_HOST=127.0.0.1
WEB_ORIGIN=http://127.0.0.1:3001
API_PUBLIC_URL=http://127.0.0.1:4001
NEXT_PUBLIC_API_PUBLIC_URL=http://127.0.0.1:4001

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:51214/template1?schema=public&sslmode=disable&pgbouncer=true&connection_limit=5
REDIS_URL=redis://127.0.0.1:6379

APP_SECRET=test-only-app-secret-min-16-chars
CREDENTIALS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Leave vendor keys empty — tests must not require live credentials
COHERE_API_KEY=
TAVILY_API_KEY=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
EASYPOST_API_KEY=
