  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, metricKey, createdAt])
  @@map("usage_meter_events")
}

/// Channel/shopper payment (NOT SaaS subscription billing)
model CommercePayment {
  id                 String                @id @default(uuid()) @db.Uuid
  organizationId     String                @map("organization_id") @db.Uuid
  customerOrderId    String                @map("customer_order_id") @db.Uuid
  channel            String                @db.VarChar(64)
  provider           String                @db.VarChar(64)
  externalPaymentId  String                @map("external_payment_id") @db.VarChar(128)
  currency           String                @db.VarChar(3)
  authorizedAmountMinor Int                @default(0) @map("authorized_amount_minor")
  capturedAmountMinor   Int                @default(0) @map("captured_amount_minor")
  refundedAmountMinor   Int                @default(0) @map("refunded_amount_minor")
  feeAmountMinor        Int?               @map("fee_amount_minor")
  netAmountMinor        Int?               @map("net_amount_minor")
  status             CommercePaymentStatus @default(pending)
  rawProviderStatus  String?               @map("raw_provider_status") @db.VarChar(64)
  metadataJson       Json                  @default("{}") @map("metadata_json")
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerOrder CustomerOrder  @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  refunds       CommerceRefund[]
  disputes      CommerceDispute[]

  @@unique([organizationId, provider, externalPaymentId])
  @@index([organizationId, customerOrderId])
  @@index([organizationId, status])
  @@map("commerce_payments")
}

model CommerceRefund {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  commercePaymentId String   @map("commerce_payment_id") @db.Uuid
  customerOrderId   String?  @map("customer_order_id") @db.Uuid
  provider          String   @db.VarChar(64)
  externalRefundId  String   @map("external_refund_id") @db.VarChar(128)
  amountMinor       Int      @map("amount_minor")
  currency          String   @db.VarChar(3)
  status            String   @db.VarChar(32)
  reason            String?  @db.VarChar(500)
  metadataJson      Json     @default("{}") @map("metadata_json")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  commercePayment CommercePayment @relation(fields: [commercePaymentId], references: [id], onDelete: Cascade)
  customerOrder   CustomerOrder?  @relation(fields: [customerOrderId], references: [id], onDelete: SetNull)

  @@unique([organizationId, provider, externalRefundId])
  @@index([organizationId, commercePaymentId])
  @@map("commerce_refunds")
}

model CommerceDispute {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  commercePaymentId  String   @map("commerce_payment_id") @db.Uuid
  provider           String   @db.VarChar(64)
  externalDisputeId  String   @map("external_dispute_id") @db.VarChar(128)
  amountMinor        Int      @map("amount_minor")
  currency           String   @db.VarChar(3)
  status             String   @db.VarChar(32)
  reason             String?  @db.VarChar(500)
  evidenceDueBy      DateTime? @map("evidence_due_by") @db.Timestamptz(3)
  metadataJson       Json     @default("{}") @map("metadata_json")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  commercePayment CommercePayment @relation(fields: [commercePaymentId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, externalDisputeId])
  @@index([organizationId])
  @@map("commerce_disputes")
}

/// Channel/processor payout to merchant (not SaaS invoice)
model CommercePayout {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  provider         String       @db.VarChar(64)
  externalPayoutId String       @map("external_payout_id") @db.VarChar(128)
  grossAmountMinor Int          @map("gross_amount_minor")
  feeAmountMinor   Int          @default(0) @map("fee_amount_minor")
  netAmountMinor   Int          @map("net_amount_minor")
  currency         String       @db.VarChar(3)
  expectedArrival  DateTime?    @map("expected_arrival") @db.Timestamptz(3)
  arrivedAt        DateTime?    @map("arrived_at") @db.Timestamptz(3)
  status           PayoutStatus @default(pending)
  metadataJson     Json         @default("{}") @map("metadata_json")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reconciliations  PaymentReconciliation[]

  @@unique([organizationId, provider, externalPayoutId])
  @@index([organizationId, status])
  @@map("commerce_payouts")
}

model PaymentReconciliation {
  id                 String               @id @default(uuid()) @db.Uuid
  organizationId     String               @map("organization_id") @db.Uuid
  commercePayoutId   String?              @map("commerce_payout_id") @db.Uuid
  status             ReconciliationStatus @default(open)
  expectedNetMinor   Int                  @default(0) @map("expected_net_minor")
  actualNetMinor     Int                  @default(0) @map("actual_net_minor")
  varianceMinor      Int                  @default(0) @map("variance_minor")
  matchedOrderCount  Int                  @default(0) @map("matched_order_count")
  unmatchedAmountMinor Int                @default(0) @map("unmatched_amount_minor")
  summaryJson        Json                 @default("{}") @map("summary_json")
  closedAt           DateTime?            @map("closed_at") @db.Timestamptz(3)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  commercePayout CommercePayout? @relation(fields: [commercePayoutId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@map("payment_reconciliations")
}

// ——— Domain 2b: Platform marketplace payments (Connect abstraction) ———
// Separate from SaaS billing and from Commerce Capital investor funds.

enum ConnectedAccountRole {
  merchant
  supplier
  service_provider
  platform
}

enum ConnectedAccountStatus {
  not_started
  onboarding
  restricted
  enabled
  disabled
  rejected
}

/// Provider-agnostic connected account (Stripe Connect Express/Custom/etc.)
model PlatformConnectedAccount {
  id                   String                 @id @default(uuid()) @db.Uuid
  organizationId       String                 @map("organization_id") @db.Uuid
  role                 ConnectedAccountRole   @default(merchant)
  provider             String                 @default("stripe_connect") @db.VarChar(32)
  providerAccountId    String?                @map("provider_account_id") @db.VarChar(128)
  status               ConnectedAccountStatus @default(not_started)
  chargesEnabled       Boolean                @default(false) @map("charges_enabled")
  payoutsEnabled       Boolean                @default(false) @map("payouts_enabled")
  detailsSubmitted     Boolean                @default(false) @map("details_submitted")
  verificationStatus   String                 @default("pending") @map("verification_status") @db.VarChar(32)
  verificationProviderRef String?             @map("verification_provider_ref") @db.VarChar(128)
  capabilitiesJson     Json                   @default("{}") @map("capabilities_json")
  metadataJson         Json                   @default("{}") @map("metadata_json")
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transfersOut PlatformTransfer[] @relation("TransferFrom")
  transfersIn  PlatformTransfer[] @relation("TransferTo")

  @@unique([organizationId, role, provider])
  @@unique([provider, providerAccountId])
  @@index([organizationId, status])
  @@map("platform_connected_accounts")
}

/// Platform fee / transfer instruction (marketplace split — not capital distribution)
model PlatformTransfer {
  id                    String   @id @default(uuid()) @db.Uuid
  organizationId        String   @map("organization_id") @db.Uuid
  fromAccountId         String?  @map("from_account_id") @db.Uuid
  toAccountId           String?  @map("to_account_id") @db.Uuid
  amountMinor           Int      @map("amount_minor")
  currency              String   @db.VarChar(3)
  platformFeeMinor      Int      @default(0) @map("platform_fee_minor")
  purpose               String   @db.VarChar(64)
  providerTransferId    String?  @map("provider_transfer_id") @db.VarChar(128)
  status                String   @default("proposed") @db.VarChar(32)
  idempotencyKey        String   @map("idempotency_key") @db.VarChar(128)
  metadataJson          Json     @default("{}") @map("metadata_json")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromAccount  PlatformConnectedAccount? @relation("TransferFrom", fields: [fromAccountId], references: [id], onDelete: SetNull)
  toAccount    PlatformConnectedAccount? @relation("TransferTo", fields: [toAccountId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, status])
  @@map("platform_transfers")
}

// ——— Domain 3: Commerce Capital Network (legally gated) ———

enum CapitalProviderStatus {
  pending
  verified
  restricted
  rejected
}

enum CampaignFundingModel {
  prepurchase
  commercial_financing
  revenue_share
  equity
  private_agreement
  sandbox
}

enum CampaignStatus {
  draft
  under_review
  legal_review_required
  approved
  open
  funding
  funded
  active
  paused
  reconciling
  completed
  failed
  cancelled
}

enum CommitmentStatus {
  initiated
  identity_verification_required
  eligibility_review
  documents_required
  payment_pending
  funded
  cancelled
  returned
  distributed
}

enum DisbursementStatus {
  proposed
  approval_required
  approved
  processing
  paid
  failed
  reversed
  reconciled
}

enum DistributionStatus {
  calculated
  approved
  paid
  failed
}

/// Capital provider (investor / commercial finance partner) — not a shopper
model CapitalProvider {
  id                 String                @id @default(uuid()) @db.Uuid
  organizationId     String                @map("organization_id") @db.Uuid
  displayName        String                @map("display_name") @db.VarChar(200)
  verificationStatus CapitalProviderStatus @default(pending) @map("verification_status")
  investorCategory   String?               @map("investor_category") @db.VarChar(64)
  jurisdiction       String                @default("CA") @db.VarChar(8)
  verificationProviderRef String?          @map("verification_provider_ref") @db.VarChar(128)
  metadataJson       Json                  @default("{}") @map("metadata_json")
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  commitments  CapitalCommitment[]

  @@index([organizationId, verificationStatus])
  @@map("capital_providers")
}

/// Campaign-based commerce funding unit
model CommerceCampaign {
  id                   String               @id @default(uuid()) @db.Uuid
  organizationId       String               @map("organization_id") @db.Uuid
  merchantOrgId        String               @map("merchant_org_id") @db.Uuid
  title                String               @db.VarChar(300)
  description          String               @default("") @db.Text
  capitalTargetMinor   Int                  @map("capital_target_minor")
  minimumCommitmentMinor Int                @default(0) @map("minimum_commitment_minor")
  maximumCommitmentMinor Int?               @map("maximum_commitment_minor")
  currency             String               @default("CAD") @db.VarChar(3)
  fundingModel         CampaignFundingModel @default(sandbox) @map("funding_model")
  status               CampaignStatus       @default(draft)
  riskRating           String               @default("unrated") @map("risk_rating") @db.VarChar(32)
  jurisdiction         String               @default("CA") @db.VarChar(8)
  legalReviewStatus    String               @default("required") @map("legal_review_status") @db.VarChar(32)
  productId            String?              @map("product_id") @db.Uuid
  supplierId           String?              @map("supplier_id") @db.Uuid
  startDate            DateTime?            @map("start_date") @db.Timestamptz(3)
  maturityDate         DateTime?            @map("maturity_date") @db.Timestamptz(3)
  economicsJson        Json                 @default("{}") @map("economics_json")
  waterfallConfigJson  Json                 @default("{}") @map("waterfall_config_json")
  riskDisclosureJson   Json                 @default("{}") @map("risk_disclosure_json")
  metadataJson         Json                 @default("{}") @map("metadata_json")
  sandbox              Boolean              @default(true)
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  budget         CampaignBudget?
  commitments    CapitalCommitment[]
  ledgerEntries  CapitalLedgerEntry[]
  disbursements  CapitalDisbursement[]
  distributions  CampaignDistribution[]

  @@index([organizationId, status])
  @@index([merchantOrgId])
  @@map("commerce_campaigns")
}

model CampaignBudget {
  id                    String   @id @default(uuid()) @db.Uuid
  organizationId        String   @map("organization_id") @db.Uuid
  campaignId            String   @unique @map("campaign_id") @db.Uuid
  inventoryBudgetMinor  Int      @default(0) @map("inventory_budget_minor")
  advertisingBudgetMinor Int     @default(0) @map("advertising_budget_minor")
  fulfillmentBudgetMinor Int     @default(0) @map("fulfillment_budget_minor")
  dutiesBudgetMinor     Int      @default(0) @map("duties_budget_minor")
  operatingReserveMinor Int      @default(0) @map("operating_reserve_minor")
  platformFeesMinor     Int      @default(0) @map("platform_fees_minor")
  merchantExpenseMinor  Int      @default(0) @map("merchant_expense_minor")
  currency              String   @default("CAD") @db.VarChar(3)
  metadataJson          Json     @default("{}") @map("metadata_json")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     CommerceCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("campaign_budgets")
}

model CapitalCommitment {
  id                 String           @id @default(uuid()) @db.Uuid
  organizationId     String           @map("organization_id") @db.Uuid
  campaignId         String           @map("campaign_id") @db.Uuid
  capitalProviderId  String           @map("capital_provider_id") @db.Uuid
  committedAmountMinor Int            @map("committed_amount_minor")
  fundedAmountMinor  Int              @default(0) @map("funded_amount_minor")
  currency           String           @default("CAD") @db.VarChar(3)
  status             CommitmentStatus @default(initiated)
  providerPaymentRef String?          @map("provider_payment_ref") @db.VarChar(128)
  metadataJson       Json             @default("{}") @map("metadata_json")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign        CommerceCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  capitalProvider CapitalProvider @relation(fields: [capitalProviderId], references: [id], onDelete: Cascade)

  @@index([organizationId, campaignId])
  @@index([capitalProviderId])
  @@map("capital_commitments")
}

/// Immutable double-entry journal for capital domain (append-only semantics in app layer)
model CapitalLedgerEntry {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  campaignId      String?  @map("campaign_id") @db.Uuid
  journalId       String   @map("journal_id") @db.Uuid
  accountCode     String   @map("account_code") @db.VarChar(64)
  /// Positive = debit, negative = credit (or use direction)
  direction       String   @db.VarChar(8)
  amountMinor     Int      @map("amount_minor")
  currency        String   @db.VarChar(3)
  memo            String   @db.VarChar(500)
  idempotencyKey  String   @map("idempotency_key") @db.VarChar(128)
  referenceType   String?  @map("reference_type") @db.VarChar(64)
  referenceId     String?  @map("reference_id") @db.Uuid
  metadataJson    Json     @default("{}") @map("metadata_json")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     CommerceCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, campaignId, accountCode])
  @@index([journalId])
  @@map("capital_ledger_entries")
}

model CapitalDisbursement {
  id                 String             @id @default(uuid()) @db.Uuid
  organizationId     String             @map("organization_id") @db.Uuid
  campaignId         String             @map("campaign_id") @db.Uuid
  recipientType      String             @map("recipient_type") @db.VarChar(32)
  recipientId        String?            @map("recipient_id") @db.Uuid
  budgetLine         String             @map("budget_line") @db.VarChar(64)
  amountMinor        Int                @map("amount_minor")
  currency           String             @db.VarChar(3)
  purpose            String             @db.VarChar(500)
  status             DisbursementStatus @default(proposed)
  approvalId         String?            @map("approval_id") @db.Uuid
  evidenceJson       Json               @default("{}") @map("evidence_json")
  providerPaymentRef String?            @map("provider_payment_ref") @db.VarChar(128)
  idempotencyKey     String             @map("idempotency_key") @db.VarChar(128)
  metadataJson       Json               @default("{}") @map("metadata_json")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     CommerceCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, campaignId, status])
  @@map("capital_disbursements")
}

model CampaignDistribution {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @map("organization_id") @db.Uuid
  campaignId           String             @map("campaign_id") @db.Uuid
  recipientType        String             @map("recipient_type") @db.VarChar(32)
  recipientId          String?            @map("recipient_id") @db.Uuid
  principalReturnedMinor Int              @default(0) @map("principal_returned_minor")
  profitDistributedMinor Int              @default(0) @map("profit_distributed_minor")
  lossAllocatedMinor   Int                @default(0) @map("loss_allocated_minor")
  feesDeductedMinor    Int                @default(0) @map("fees_deducted_minor")
  currency             String             @db.VarChar(3)
  status               DistributionStatus @default(calculated)
  calculationVersion   String             @map("calculation_version") @db.VarChar(32)
  inputsJson           Json               @default("{}") @map("inputs_json")
  providerPaymentRef   String?            @map("provider_payment_ref") @db.VarChar(128)
  metadataJson         Json               @default("{}") @map("metadata_json")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     CommerceCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([organizationId, campaignId])
  @@map("campaign_distributions")
}

// ——— Client-owned commerce operating capital (managed commerce infrastructure) ———
// Distinct from campaign investor capital and SaaS billing.

enum CapitalAccountStatus {
  pending_verification
  additional_information_required
  payments_enabled
  funding_enabled
  payout_disabled
  active
  restricted
  suspended
  closed
}

enum MandateStatus {
  draft
  approved
  paused
  revoked
}

enum MandateRiskLevel {
  conservative
  balanced
  growth
}

enum AllocationStatus {
  proposed
  approved
  reserved
  deployed
  reconciling
  closed
  cancelled
}

enum FundingIntentStatus {
  created
  provider_opened
  pending
  confirmed
  failed
  cancelled
}

/// Client-owned commerce capital account — ledger of partner-verified funds, not editable wallet
model CommerceCapitalAccount {
  id                 String               @id @default(uuid()) @db.Uuid
  organizationId     String               @map("organization_id") @db.Uuid
  ownerType          String               @default("business") @map("owner_type") @db.VarChar(32)
  /// Partner connected account / custody reference — never TradeOps operating bank
  provider           String               @default("pending") @db.VarChar(32)
  providerAccountId  String?              @map("provider_account_id") @db.VarChar(128)
  currency           String               @default("CAD") @db.VarChar(3)
  status             CapitalAccountStatus @default(pending_verification)
  verificationJson   Json                 @default("{}") @map("verification_json")
  capabilityJson     Json                 @default("{}") @map("capability_json")
  metadataJson       Json                 @default("{}") @map("metadata_json")
  sandbox            Boolean              @default(true)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mandates     CommerceMandate[]
  allocations  CapitalAllocation[]
  fundingIntents FundingIntent[]

  @@unique([organizationId, currency])
  @@index([organizationId, status])
  @@map("commerce_capital_accounts")
}

/// Explicit spending / deployment policy — AI and workflows must stay inside these limits
model CommerceMandate {
  id                       String          @id @default(uuid()) @db.Uuid
  organizationId           String          @map("organization_id") @db.Uuid
  capitalAccountId         String          @map("capital_account_id") @db.Uuid
  maximumCapitalMinor      Int             @map("maximum_capital_minor")
  maximumProductExposureMinor Int          @default(0) @map("maximum_product_exposure_minor")
  maximumDailySpendMinor   Int             @default(0) @map("maximum_daily_spend_minor")
  maximumMonthlySpendMinor Int             @default(0) @map("maximum_monthly_spend_minor")
  maximumAdvertisingMinor  Int             @default(0) @map("maximum_advertising_minor")
  maximumRefundExposureMinor Int           @default(0) @map("maximum_refund_exposure_minor")
  minimumMarginBps         Int             @default(0) @map("minimum_margin_bps")
  approvalThresholdMinor   Int             @default(0) @map("approval_threshold_minor")
  maximumDeliveryDays      Int             @default(30) @map("maximum_delivery_days")
  allowedChannelsJson      Json            @default("[]") @map("allowed_channels_json")
  allowedCategoriesJson    Json            @default("[]") @map("allowed_categories_json")
  allowedCountriesJson     Json            @default("[\"CA\"]") @map("allowed_countries_json")
  riskLevel                MandateRiskLevel @default(conservative) @map("risk_level")
  status                   MandateStatus   @default(draft)
  metadataJson             Json            @default("{}") @map("metadata_json")
  approvedAt               DateTime?       @map("approved_at") @db.Timestamptz(3)
  createdAt                DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  capitalAccount CommerceCapitalAccount @relation(fields: [capitalAccountId], references: [id], onDelete: Cascade)
  allocations    CapitalAllocation[]

  @@index([organizationId, status])
  @@index([capitalAccountId])
  @@map("commerce_mandates")
}

/// Capital reserved/deployed against a commerce case or product opportunity
model CapitalAllocation {
  id                 String           @id @default(uuid()) @db.Uuid
  organizationId     String           @map("organization_id") @db.Uuid
  capitalAccountId   String           @map("capital_account_id") @db.Uuid
  mandateId          String?          @map("mandate_id") @db.Uuid
  commerceCaseId     String?          @map("commerce_case_id") @db.Uuid
  productId          String?          @map("product_id") @db.Uuid
  amountReservedMinor Int             @default(0) @map("amount_reserved_minor")
  amountDeployedMinor Int             @default(0) @map("amount_deployed_minor")
  amountReturnedMinor Int             @default(0) @map("amount_returned_minor")
  currency           String           @db.VarChar(3)
  status             AllocationStatus @default(proposed)
  economicsJson      Json             @default("{}") @map("economics_json")
  /// forecast | committed | settled | realized — never mix labels
  evidenceJson       Json             @default("{}") @map("evidence_json")
  idempotencyKey     String           @map("idempotency_key") @db.VarChar(128)
  metadataJson       Json             @default("{}") @map("metadata_json")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  capitalAccount CommerceCapitalAccount @relation(fields: [capitalAccountId], references: [id], onDelete: Cascade)
  mandate        CommerceMandate?       @relation(fields: [mandateId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, capitalAccountId, status])
  @@map("capital_allocations")
}

/// Funding intent — usable capital only after verified provider event (not browser redirect)
model FundingIntent {
  id                   String              @id @default(uuid()) @db.Uuid
  organizationId       String              @map("organization_id") @db.Uuid
  capitalAccountId     String              @map("capital_account_id") @db.Uuid
  amountMinor          Int                 @map("amount_minor")
  currency             String              @db.VarChar(3)
  status               FundingIntentStatus @default(created)
  provider             String              @default("sandbox") @db.VarChar(32)
  providerReference    String?             @map("provider_reference") @db.VarChar(128)
  idempotencyKey       String              @map("idempotency_key") @db.VarChar(128)
  metadataJson         Json                @default("{}") @map("metadata_json")
  confirmedAt          DateTime?           @map("confirmed_at") @db.Timestamptz(3)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  capitalAccount CommerceCapitalAccount @relation(fields: [capitalAccountId], references: [id], onDelete: Cascade)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, capitalAccountId, status])
  @@map("funding_intents")
}
