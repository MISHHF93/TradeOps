  @@unique([organizationId, productId])
  @@index([organizationId, currentStage])
  @@index([organizationId, stageStatus])
  @@map("commerce_cases")
}

// ——— Dual financial domains: SaaS billing vs commerce payments (never mix) ———

enum BillingAccountStatus {
  active
  past_due
  suspended
  cancelled
}

enum BillingSubscriptionStatus {
  trialing
  active
  past_due
  unpaid
  cancelled
  incomplete
}

enum CommercePaymentStatus {
  pending
  authorized
  captured
  partially_refunded
  refunded
  failed
  disputed
  cancelled
}

enum PayoutStatus {
  pending
  in_transit
  paid
  failed
}

enum ReconciliationStatus {
  open
  matched
  variance
  closed
}

/// SaaS billing account (TradeOps subscription customer — not shopper payments)
model BillingAccount {
  id                 String               @id @default(uuid()) @db.Uuid
  organizationId     String               @map("organization_id") @db.Uuid
  provider           String               @default("stripe") @db.VarChar(32)
  providerCustomerId String               @map("provider_customer_id") @db.VarChar(128)
  status             BillingAccountStatus @default(active)
  defaultCurrency    String               @default("USD") @map("default_currency") @db.VarChar(3)
  metadataJson       Json                 @default("{}") @map("metadata_json")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization  Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions BillingSubscription[]
  invoices      BillingInvoice[]

  @@unique([organizationId, provider])
  @@unique([provider, providerCustomerId])
  @@index([organizationId])
  @@map("billing_accounts")
}

/// SaaS subscription (Stripe Billing)
model BillingSubscription {
  id                     String                     @id @default(uuid()) @db.Uuid
  organizationId         String                     @map("organization_id") @db.Uuid
  billingAccountId       String                     @map("billing_account_id") @db.Uuid
  providerSubscriptionId String                     @map("provider_subscription_id") @db.VarChar(128)
  planId                 String                     @map("plan_id") @db.VarChar(64)
  status                 BillingSubscriptionStatus  @default(incomplete)
  periodStart            DateTime?                  @map("period_start") @db.Timestamptz(3)
  periodEnd              DateTime?                  @map("period_end") @db.Timestamptz(3)
  cancelAtPeriodEnd      Boolean                    @default(false) @map("cancel_at_period_end")
  metadataJson           Json                       @default("{}") @map("metadata_json")
  createdAt              DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@unique([providerSubscriptionId])
  @@index([organizationId, status])
  @@map("billing_subscriptions")
}

/// SaaS invoice snapshot (Stripe invoices)
model BillingInvoice {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  billingAccountId String   @map("billing_account_id") @db.Uuid
  providerInvoiceId String  @map("provider_invoice_id") @db.VarChar(128)
  status           String   @db.VarChar(32)
  currency         String   @db.VarChar(3)
