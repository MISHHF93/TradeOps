// TradeOps — identity + commerce vertical slice

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  owner
  admin
  manager
  analyst
  viewer
  developer
}

enum ConnectorStatus {
  not_configured
  credentials_required
  connected
  authorization_expired
  permission_limited
  rate_limited
  unhealthy
  disabled
}

enum ListingStatus {
  draft
  pending_approval
  active
  paused
  rejected
}

enum ApprovalStatus {
  pending
  approved
  rejected
  cancelled
}

enum ApprovalKind {
  publish_listing
  supplier_purchase_order
  price_change
  simulation_only
}

enum OrderStatus {
  pending
  paid
  fulfilled
  cancelled
  refunded
}

enum PolicyOutcome {
  approved
  approved_with_conditions
  manual_review
  blocked
}

enum CommerceSignalType {
  BUY
  SELL
  HOLD
  SCALE
  REDUCE
  EXIT
  BLOCKED
}

/// Customer segment for onboarding, packing, and UX composition
enum CustomerSegment {
  individual
  smb
  agency
  enterprise
}

/// Commercial plan tier (entitlements enforced server-side)
enum PlanTier {
  starter
  growth
  agency
  business
  enterprise
  evaluation
}

/// Multi-tenant deployment model
enum TenantDeploymentMode {
  pooled
  siloed
  bridge
}

/// Persona-adaptive workspace mode (UI composition; same data model)
enum WorkspacePersona {
  founder
  operator
  analyst
  procurement
  finance
  executive
  agency
  auditor
  /// Primary Commerce OS personas
  researcher
  developer
  administrator
}

/// Canonical tenant organization type (retail + industrial commerce OS)
enum OrganizationType {
  retailer
  marketplace_seller
  distributor
  wholesaler
  manufacturer
  industrial_supplier
  procurement_organization
  logistics_provider
  enterprise_group
  service_provider
}

/// Primary commerce operating mode for the tenant
enum CommerceMode {
  retail
  b2b
  industrial
  hybrid
}

enum TenantStatus {
  active
  suspended
  provisioning
  closed
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  incomplete
}

enum WorkspaceKind {
  default
  business_unit
  brand
  region
  site
  industrial_plant
}

enum MembershipStatus {
  active
  invited
  suspended
}

/// Permission effect for per-user overrides (membership-scoped)
enum PermissionEffect {
  allow
  deny
}

/// Canonical Tenant = Organization (table retained for backward compatibility).
/// Hierarchy: Platform → Tenant → Workspace → Team → User → Membership → Role → Permission
model Organization {
  id             String               @id @default(uuid()) @db.Uuid
  /// Stable non-secret public identifier for URLs / support (not a security boundary)
  publicId       String               @unique @default(uuid()) @map("public_id") @db.Uuid
  name           String               @db.VarChar(200)
  slug           String               @unique @db.VarChar(64)
  legalName      String?              @map("legal_name") @db.VarChar(300)
  organizationType OrganizationType   @default(retailer) @map("organization_type")
  industry       String?              @db.VarChar(128)
  commerceMode   CommerceMode         @default(retail) @map("commerce_mode")
  region         String?              @db.VarChar(64)
  country        String?              @db.VarChar(2)
  defaultCurrency String              @default("USD") @map("default_currency") @db.VarChar(3)
  defaultLanguage String              @default("en") @map("default_language") @db.VarChar(16)
  timezone       String               @default("UTC") @db.VarChar(64)
  /// SaaS customer segment
  segment        CustomerSegment      @default(individual)
  planTier       PlanTier             @default(evaluation) @map("plan_tier")
  /// Mirror of commercial plan label (string for billing provider flexibility)
  subscriptionPlan String?            @map("subscription_plan") @db.VarChar(64)
  subscriptionStatus SubscriptionStatus @default(trialing) @map("subscription_status")
  billingCustomerId String?           @map("billing_customer_id") @db.VarChar(128)
  tenantStatus   TenantStatus         @default(active) @map("tenant_status")
  deploymentMode TenantDeploymentMode @default(pooled) @map("deployment_mode")
  /// Optional parent org (agency → client, or corporate hierarchy)
  parentOrganizationId String?        @map("parent_organization_id") @db.Uuid
  businessModel  String?              @map("business_model") @db.VarChar(64)
  onboardingStep String               @default("created") @map("onboarding_step") @db.VarChar(64)
  onboardingStatus String             @default("created") @map("onboarding_status") @db.VarChar(64)
  onboardingComplete Boolean          @default(false) @map("onboarding_complete")
  dataResidencyRegion String?         @map("data_residency_region") @db.VarChar(32)
  retentionPolicy Json                @default("{}") @map("retention_policy")
  featureFlags   Json                 @default("{}") @map("feature_flags")
  settings       Json                 @default("{}") @map("settings")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  parentOrganization     Organization?  @relation("OrgHierarchy", fields: [parentOrganizationId], references: [id], onDelete: SetNull)
  childOrganizations     Organization[] @relation("OrgHierarchy")
  memberships            Membership[]
  workspaces             Workspace[]
  teams                  Team[]
  roles                  Role[]
  permissionOverrides    UserPermissionOverride[]
  auditEvents            AuditEvent[]
  activeSessions         Session[]                 @relation("SessionActiveOrganization")
  connectorInstallations ConnectorInstallation[]
  suppliers              Supplier[]
  products               Product[]
  salesChannels          SalesChannel[]
  listings               Listing[]
  opportunities          Opportunity[]
  signals                CommerceSignal[]
  forecasts              DemandForecast[]
  policyAssessments      PolicyAssessment[]
  customerOrders         CustomerOrder[]
  supplierPurchaseOrders SupplierPurchaseOrder[]
  fulfillments           Fulfillment[]
  approvals              Approval[]
  simulationRuns         SimulationRun[]
  profitabilitySnapshots ProfitabilitySnapshot[]
  predictionOutcomes     PredictionOutcome[]
  modelVersions          ModelVersion[]
  // Professor-mode foundations (live loops / AI / harmonization / events)
  productIdentifiers     ProductIdentifier[]
  externalPayloads       ExternalPayload[]
  identityLinks          IdentityLink[]
  commerceEvents         CommerceEvent[]
  webhookReceipts        WebhookReceipt[]
  shadowDecisions        ShadowDecision[]
  operatorRuns           OperatorRun[]
  operatorRecommendations OperatorRecommendation[]
  connectorHealthEvents  ConnectorHealthEvent[]
  usageMeters            UsageMeter[]
  watchlistItems         ProductWatchlistItem[]
  productArtifacts       ProductArtifact[]
  commerceCases          CommerceCase[]
  billingAccounts        BillingAccount[]
  billingSubscriptions   BillingSubscription[]
  billingInvoices        BillingInvoice[]
  commercePayments       CommercePayment[]
  commerceRefunds        CommerceRefund[]
  commerceDisputes       CommerceDispute[]
  commercePayouts        CommercePayout[]
  paymentReconciliations PaymentReconciliation[]
  billingWebhookEvents   BillingWebhookEvent[]
  usageMeterEvents       UsageMeterEvent[]
  // Platform marketplace payments (Connect abstraction — not capital)
  platformConnectedAccounts PlatformConnectedAccount[]
  platformTransfers         PlatformTransfer[]
  // Commerce Capital Network (gated — not public solicitation by default)
  capitalProviders          CapitalProvider[]
  commerceCampaigns         CommerceCampaign[]
  capitalCommitments        CapitalCommitment[]
  capitalLedgerEntries      CapitalLedgerEntry[]
  capitalDisbursements      CapitalDisbursement[]
  campaignDistributions     CampaignDistribution[]
  campaignBudgets           CampaignBudget[]
  // Client-owned commerce operating capital (managed commerce — not pooled fund)
  commerceCapitalAccounts   CommerceCapitalAccount[]
  commerceMandates          CommerceMandate[]
  capitalAllocations        CapitalAllocation[]
  fundingIntents            FundingIntent[]

  @@index([parentOrganizationId])
  @@index([tenantStatus])
  @@index([organizationType])
  @@index([commerceMode])
  @@map("organizations")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(320)
  displayName  String   @map("display_name") @db.VarChar(200)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  memberships Membership[]
  auditEvents AuditEvent[]
  sessions    Session[]
  approvals   Approval[]   @relation("ApprovalActor")

  @@map("users")
}

/// Org membership only — never put a global role on User.
/// `role` is a compatibility primary SystemRole; authoritative grants live in MembershipRole + overrides.
model Membership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  /// Legacy primary system role (kept for backward compatibility; membership-scoped)
  role           SystemRole       @default(viewer)
  status         MembershipStatus @default(active)
  /// Preferred workspace persona for adaptive navigation
  workspacePersona WorkspacePersona @default(founder) @map("workspace_persona")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipRoles       MembershipRole[]
  workspaceMemberships  WorkspaceMembership[]
  teamMemberships       TeamMembership[]
  permissionOverrides   UserPermissionOverride[]

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, status])
  @@map("memberships")
}

/// Business unit / brand / site under a tenant
model Workspace {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  publicId       String        @unique @default(uuid()) @map("public_id") @db.Uuid
  name           String        @db.VarChar(200)
  slug           String        @db.VarChar(64)
  kind           WorkspaceKind @default(default)
  isDefault      Boolean       @default(false) @map("is_default")
  settings       Json          @default("{}")
  status         TenantStatus  @default(active)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships  WorkspaceMembership[]
  teams        Team[]
  activeSessions Session[]           @relation("SessionActiveWorkspace")

  @@unique([organizationId, slug])
  @@index([organizationId, isDefault])
  @@map("workspaces")
}

model WorkspaceMembership {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  membershipId   String   @map("membership_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  /// Optional workspace-local system role override (null = inherit org membership)
  role           SystemRole?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([organizationId, userId])
  @@index([membershipId])
  @@map("workspace_memberships")
}

model Team {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  workspaceId    String?      @map("workspace_id") @db.Uuid
  name           String       @db.VarChar(200)
  slug           String       @db.VarChar(64)
  description    String?      @db.VarChar(500)
  status         TenantStatus @default(active)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  memberships  TeamMembership[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([workspaceId])
  @@map("teams")
}

model TeamMembership {
  id             String   @id @default(uuid()) @db.Uuid
  teamId         String   @map("team_id") @db.Uuid
  membershipId   String   @map("membership_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  role           SystemRole @default(viewer)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([organizationId, userId])
  @@index([membershipId])
  @@map("team_memberships")
}

/// RBAC role — system templates (organizationId null) or tenant-custom roles
model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  key            String   @db.VarChar(64)
  name           String   @db.VarChar(128)
  description    String?  @db.VarChar(500)
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  membershipRoles MembershipRole[]

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("roles")
}

/// Permission catalog row (key matches Permission contract string)
model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(64)
  name        String   @db.VarChar(128)
  description String?  @db.VarChar(500)
  category    String   @default("general") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  rolePermissions RolePermission[]
  overrides       UserPermissionOverride[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model MembershipRole {
  id           String   @id @default(uuid()) @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleId])
  @@index([roleId])
  @@map("membership_roles")
}

/// Per-user allow/deny within a tenant (membership-scoped; never global on User alone)
model UserPermissionOverride {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  membershipId   String           @map("membership_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  permissionId   String           @map("permission_id") @db.Uuid
  effect         PermissionEffect
  reason         String?          @db.VarChar(500)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([membershipId, permissionId])
  @@index([organizationId, userId])
  @@map("user_permission_overrides")
}

/// Metered usage for SaaS entitlements (do not bill platform-caused failures)
model UsageMeter {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  metricKey      String   @map("metric_key") @db.VarChar(64)
  periodKey      String   @map("period_key") @db.VarChar(16)
  quantity       Int      @default(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, metricKey, periodKey])
  @@index([organizationId, periodKey])
  @@map("usage_meters")
}

model Session {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  tokenHash            String    @unique @map("token_hash") @db.VarChar(64)
  activeOrganizationId String?   @map("active_organization_id") @db.Uuid
  /// Active business unit / workspace under the tenant (validated against workspace membership)
  activeWorkspaceId    String?   @map("active_workspace_id") @db.Uuid
  expiresAt            DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt            DateTime? @map("revoked_at") @db.Timestamptz(3)
  ipAddress            String?   @map("ip_address") @db.VarChar(64)
  userAgent            String?   @map("user_agent") @db.VarChar(512)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganization Organization? @relation("SessionActiveOrganization", fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  activeWorkspace    Workspace?    @relation("SessionActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@index([activeWorkspaceId])
  @@map("sessions")
}

model AuditEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String   @db.VarChar(128)
  resourceType   String   @map("resource_type") @db.VarChar(64)
  resourceId     String?  @map("resource_id") @db.VarChar(128)
  metadata       Json     @default("{}")
  ipAddress      String?  @map("ip_address") @db.VarChar(64)
  userAgent      String?  @map("user_agent") @db.VarChar(512)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

model ConnectorInstallation {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  providerKey    String          @map("provider_key") @db.VarChar(64)
  displayName    String          @map("display_name") @db.VarChar(200)
  family         String          @db.VarChar(32)
  isFixture      Boolean         @default(false) @map("is_fixture")
  status         ConnectorStatus @default(not_configured)
  capabilities   Json            @default("[]")
  lastHealthAt   DateTime?       @map("last_health_at") @db.Timestamptz(3)
  lastError      String?         @map("last_error") @db.VarChar(500)
  /// Ops metrics: quota, throughput, lastWebhookAt, lastPollAt, rateLimitHints
  metadataJson   Json            @default("{}") @map("metadata_json")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, providerKey])
  @@index([organizationId])
  @@map("connector_installations")
}

model Supplier {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  name               String   @db.VarChar(200)
  sourcePlatform     String   @map("source_platform") @db.VarChar(64)
  externalId         String   @map("external_id") @db.VarChar(128)
  reliabilityScore   Int      @default(70) @map("reliability_score")
  dataConfidence     Float    @default(0.7) @map("data_confidence")
  collectedAt        DateTime @default(now()) @map("collected_at") @db.Timestamptz(3)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  offers       SupplierOffer[]

  @@unique([organizationId, sourcePlatform, externalId])
  @@index([organizationId])
  @@map("suppliers")
}

model SupplierOffer {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  supplierId         String   @map("supplier_id") @db.Uuid
  productId          String?  @map("product_id") @db.Uuid
  sourcePlatform     String   @map("source_platform") @db.VarChar(64)
  externalId         String   @map("external_id") @db.VarChar(128)
  title              String   @db.VarChar(500)
  costMinor          Int      @map("cost_minor")
  shippingCostMinor  Int      @map("shipping_cost_minor")
  currency           String   @db.VarChar(3)
  inventoryQuantity  Int      @default(0) @map("inventory_quantity")
  dataConfidence     Float    @default(0.7) @map("data_confidence")
  collectedAt        DateTime @default(now()) @map("collected_at") @db.Timestamptz(3)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([organizationId, sourcePlatform, externalId])
  @@index([organizationId, productId])
  @@map("supplier_offers")
}

model Product {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  title               String   @db.VarChar(500)
  description         String   @db.Text
  category            String   @db.VarChar(120)
  sourcePlatform      String   @map("source_platform") @db.VarChar(64)
  externalId          String   @map("external_id") @db.VarChar(128)
  currency            String   @db.VarChar(3) @default("USD")
  supplierCostMinor   Int      @map("supplier_cost_minor")
  shippingCostMinor   Int      @map("shipping_cost_minor")
  targetPriceMinor    Int      @map("target_price_minor")
  marketplaceFeeMinor Int      @map("marketplace_fee_minor")
  paymentFeeMinor     Int      @map("payment_fee_minor")
  adAllocationMinor   Int      @default(0) @map("ad_allocation_minor")
  returnReserveMinor  Int      @default(0) @map("return_reserve_minor")
  inventoryQuantity   Int      @default(0) @map("inventory_quantity")
  rating              Float    @default(0)
  reviewCount         Int      @default(0) @map("review_count")
  dataConfidence      Float    @default(0.7) @map("data_confidence")
  dataFreshnessAt     DateTime @default(now()) @map("data_freshness_at") @db.Timestamptz(3)
  schemaVersion       String   @default("2") @map("schema_version") @db.VarChar(16)
  brand               String?  @db.VarChar(200)
  manufacturer        String?  @db.VarChar(200)
  condition           String?  @db.VarChar(64)
  countryOfOrigin     String?  @map("country_of_origin") @db.VarChar(2)
  hsCode              String?  @map("hs_code") @db.VarChar(16)
