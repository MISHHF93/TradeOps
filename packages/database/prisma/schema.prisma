  errorMessage    String?  @map("error_message") @db.VarChar(1000)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  processedAt     DateTime? @map("processed_at") @db.Timestamptz(3)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId])
  @@index([provider, eventType])
  @@map("billing_webhook_events")
}

/// Granular usage events for future metered billing (meters, not legacy usage records)
model UsageMeterEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  metricKey      String   @map("metric_key") @db.VarChar(64)
