}

// ——— Commerce operating procedure spine ———

enum CommerceStage {
  discover
  evaluate
  qualify
  prepare
  approve
  publish
  sell
  source
  fulfill
  reconcile
  learn
  closed
}

enum CommerceStageStatus {
  not_started
  ready
  in_progress
  waiting
  blocked
  completed
  failed
}

/// One product opportunity moving through the canonical commerce lifecycle.
model CommerceCase {
  id                     String              @id @default(uuid()) @db.Uuid
  organizationId         String              @map("organization_id") @db.Uuid
  productId              String              @map("product_id") @db.Uuid
  selectedSupplierOfferId String?            @map("selected_supplier_offer_id") @db.Uuid
  selectedChannelId      String?             @map("selected_channel_id") @db.Uuid
  listingDraftId         String?             @map("listing_draft_id") @db.Uuid
  publishedListingId     String?             @map("published_listing_id") @db.Uuid
  currentStage           CommerceStage       @default(discover) @map("current_stage")
  stageStatus            CommerceStageStatus @default(not_started) @map("stage_status")
  recommendation         String?             @db.VarChar(64)
  opportunityScore       Int?                @map("opportunity_score")
  confidence             Float?
  expectedProfitMinor    Int?                @map("expected_profit_minor")
  realizedProfitMinor    Int?                @map("realized_profit_minor")
  nextActionCode         String?             @map("next_action_code") @db.VarChar(64)
  nextActionLabel        String?             @map("next_action_label") @db.VarChar(500)
  blockerCode            String?             @map("blocker_code") @db.VarChar(64)
  blockerMessage         String?             @map("blocker_message") @db.VarChar(1000)
  ownerUserId            String?             @map("owner_user_id") @db.Uuid
  metadataJson           Json                @default("{}") @map("metadata_json")
  stageHistoryJson       Json                @default("[]") @map("stage_history_json")
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
